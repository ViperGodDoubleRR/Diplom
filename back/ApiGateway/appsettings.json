{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },

      "reg": {
        "ClusterId": "regCluster",
        "Match": {
          "Path": "/reg/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/reg" }
        ]
      },

      "user": {
        "ClusterId": "userCluster",
        "Match": {
          "Path": "/user/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/user" }
        ]
      },
      "post": {
        "ClusterId": "postCluster",
        "Match": {
          "Path": "/post/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/post" }
        ]
      }
    },

    "Clusters": {
      "authCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5290" }
        }
      },

      "regCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5291" }
        }
      },

      "userCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5095" }
        }
      },
      "postCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5096" }
        }
      }
    }
  }

}
